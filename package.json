{
  "name": "vite-plugin-vitepress-auto-nav",
  "version": "3.0.0",
  "description": "自动生成vitepress的nav与sidebar",
  "keywords": [
    "vitepress",
    "vite-plugin",
    "vitepress-plugin",
    "vitepress-auto",
    "vitepress-gitbook",
    "vitepress-summary",
    "auto-nav",
    "auto-sidebar",
    "auto-menu"
  ],
  "homepage": "https://xaviw.github.io/XaviDocs/",
  "bugs": "https://github.com/Xaviw/vite-plugin-vitepress-auto-nav/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xaviw/vite-plugin-vitepress-auto-nav.git"
  },
  "license": "MIT",
  "author": "xavi",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . --ignore-path .gitignore",
    "test:unit": "vitest run tests/unit --coverage.enabled=false",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint-staged"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "fast-glob": "^3.3.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "vitepress": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.5.0"
}